# Copy this file to .env and fill in your real GoCardless credentials.
# Never commit .env - it is already covered by .gitignore.

# GoCardless API access token (Developers > Create > Access token in the GoCardless dashboard).
# Use a sandbox token while testing, a live token only once you're ready to take real payments.
GOCARDLESS_ACCESS_TOKEN=

# "sandbox" while testing, "live" once you're ready to go live.
GOCARDLESS_ENVIRONMENT=sandbox

# Used to build the redirect URL GoCardless sends customers back to after
# they finish setting up their Direct Debit. Should be the public URL of
# this site, with no trailing slash, e.g. https://spearexteriors.co.uk
SITE_URL=http://localhost:4000

# Optional but recommended: the webhook signing secret shown when you add a
# webhook endpoint in the GoCardless dashboard (Developers > Webhooks).
# Point that webhook at {SITE_URL}/api/gocardless/webhooks
GOCARDLESS_WEBHOOK_SECRET=

# Optional, comma-separated. The server rejects requests whose Host header
# isn't in its allowlist (localhost/127.0.0.1 and SITE_URL's hostname are
# always allowed). Add any other hostnames the site is reachable on, e.g. a
# staging domain or Azure's default *.azurestaticapps.net hostname.
ALLOWED_HOSTS=
